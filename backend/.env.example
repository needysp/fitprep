# Google OAuth 2.0 client (see README for setup steps)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Any long random string, e.g. `python -c "import secrets; print(secrets.token_hex(32))"`
SESSION_SECRET=change-me

# Where the OAuth callback redirects after login (prod: your public origin)
FRONTEND_URL=http://localhost:5173

# Optional overrides
# DATABASE_URL=sqlite:///./app.db
# SECURE_COOKIES=false   # set true in prod behind HTTPS
